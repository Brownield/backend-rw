{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "tabWidth": 4,
  "singleQuote": true,
  "printWidth": 100,
  "overrides": [
    {
      "files": [
        "*.json",
        "**/*.json",
        "*.jsonc",
        "**/*.jsonc",
        "*.yaml",
        "**/*.yaml",
        "*.yml",
        "**/*.yml",
        "*.md",
        "**/*.md"
      ],
      "options": { "tabWidth": 2 }
    }
  ]
}
